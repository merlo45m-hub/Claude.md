        data = Image.create_from_width_height(16, 16, false, Image.FORMAT_L8)
        # Simple white circle texture for XP bar
        for x in range(16):
            for y in range(16):
                var dx = x - 7.5
                var dy = y - 7.5
                var dist = sqrt(dx*dx + dy*dy)
                if dist < 7.5:
                    Image.set_pixel(id=9, x=x, y=y, color=Color(1, 1, 1, 1))
                else:
                    Image.set_pixel(id=9, x=x, y=y, color=Color(0, 0, 0, 0))
