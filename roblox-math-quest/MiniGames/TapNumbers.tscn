# Resources
[subresource type="StreamTexture" id=0]
    stream = Subresource type="ImageTexture" id=1]
        [subresource type="Image" id=2]
            data = Image.create_from_width_height(64, 64, false, Image.FORMAT_RGBA8)
            # Draw a simple circle (red) for the target
            for x in range(64):
                for y in range(64):
                    var dx = x - 31.5
                    var dy = y - 31.5
                    var dist = sqrt(dx*dx + dy*dy)
                    if dist < 10:
                        Image.set_pixel(id=2, x=x, y=y, color=Color(1, 0, 0, 1))
                    else:
                        Image.set_pixel(id=2, x=x, y=y, color=Color(0, 0, 0, 0))